# Copy to .env for local dev. Real values come from the environment in production.

# --- Core ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Fernet key encrypting Tabbycat API tokens + private url keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# When True, sync auto-creates a login-disabled (passwordless) account for any
# Tabbycat adjudicator email without one. People set a password via the reset
# flow; no invite mail is sent. Requires a working email backend (below) for the
# reset link to actually reach them.
# AUTO_CREATE_ADJUDICATOR_ACCOUNTS=False

# Lock the login form after this many failed attempts (per IP and per email),
# for LOGIN_THROTTLE_TIMEOUT seconds.
# LOGIN_THROTTLE_LIMIT=5
# LOGIN_THROTTLE_TIMEOUT=900

# Flag an active Tabbycat instance red in the admin when its last sync is older
# than this (minutes) — usually means the sync cron has died.
# SYNC_STALE_AFTER_MINUTES=60

# --- Database (defaults to local SQLite if unset) ---
# DATABASE_URL=postgres://user:pass@host:5432/compass

# --- Email (defaults to console backend; set SMTP to send real mail) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Compass <noreply@example.com>

# --- Production only ---
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=2592000
# CSRF_TRUSTED_ORIGINS=https://compass.example.com
